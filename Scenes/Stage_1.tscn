[sub_resource type="GDScript" id="GDScript_lfxmx"]
script/source = "extends ParallaxLayer

func _process(delta: float) -> void:
	motion_offset.x -= delta * 20
"

[sub_resource type="GDScript" id="GDScript_j3e1v"]
script/source = "extends ParallaxLayer

@onready var big_waterReflect = $BigWaterReflect
@onready var big_waterReflect2 = $BigWaterReflect2
@onready var medium_waterReflect = $MediumWaterReflect
@onready var small_waterReflect = $SmallWaterReflect

func _ready() -> void:
	big_waterReflect.play(\"big\")
	big_waterReflect2.play(\"big\")
	medium_waterReflect.play(\"medium\")
	small_waterReflect.play(\"small\")
"

