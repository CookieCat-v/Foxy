[sub_resource type="GDScript" id="GDScript_w2s81"]
script/source = "extends Area2D

func _ready() -> void:
	$AnimatedSprite2D.play(\"default\")

func _on_body_entered(body: Node2D) -> void:
	if body.name == \"Player\":
		var label = body.get_parent().get_node(\"CanvasLayer\").get_node(\"ScoreLabel\")
		var currentScore = int(label.text)
		currentScore += 100
		label.text = str(currentScore)
		AudioManager.play_sound(\"coin_pickup\")
		queue_free()
"

